// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// Cấu hình Generator - "Xưởng sản xuất" code client
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

// Cấu hình Datasource - "Địa chỉ" nhà kho dữ liệu 
datasource db {
  provider = "postgresql"
}

// Định nghĩa Enum - Tập hợp các giá trị cố định 
enum Role{
  ADMIN
  MEMBER
}

enum TaskStatus{
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority{
  LOW
  MEDIUM
  HIGH
}




// Model User - "Bản vẽ" của bảng người dùng
model User{
  // UUID giúp định danh khó đoán và an toàn hơn ID tự tăng (1, 2, 3)
  id  String  @id @default(uuid())
  // @unique đảm bảo không bao giờ có 2 người trùng email
  email String  @unique
  //  @map giúp đặt tên field trong code camelCase nhưng DB là snake_case
  passwordHash  String  @map("password_hash")
  // Dấu ? nghĩa là Optional (có thể để trống)
  fullname  String? @map("fullname")
  avatar    String?  @map("avatar") 
  // Mặc định mọi người đăng ký là MEMBER
  role  Role  @default(MEMBER)
  // Quản lý trạng thái
  emailVerifiedAt DateTime? @map("email_verified_at")
  refreshTokenVersion Int @default(1) @map("refresh_token_version")
  // Thời gian hệ thống
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  // Dùng cho Soft Delete
  deletedAt  DateTime?  @map("deleted_at")
  tasks Task[]

  @@map("users") // Tên bảng trong db 

  ownedProjects Project[] @relation("ProjectOwner")
  memberProjects Project[]  @relation("ProjectMembers")
  comments Comment[]
}


// Model Project  là container chứa các Task.
model Project{
  id  String @id @default(uuid())
  title String @map("title")
  description String? @map("description")
  ownerId String @map("owner_id")
  tasks Task[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt  @map("updated_at")
  deletedAt  DateTime?  @map("deleted_at")

  @@map("projects")

  owner User @relation("ProjectOwner", fields: [ownerId], references: [id])
  members User[]  @relation("ProjectMembers")
}


model Task{
  id  String @id @default(uuid())
  title String 
  status  TaskStatus @default(TODO)
  priority  TaskPriority  @default(MEDIUM)
  dueDate DateTime? @map("due_date")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt  @map("updated_at")
  deletedAt  DateTime?  @map("deleted_at")

  // Quan hệ 1-n với User (Người thực hiện)
  assigneeId  String? @map("assignee_id")
  assignee  User? @relation(fields: [assigneeId], references: [id])

  // Quan hệ 1-n với Project (Dự án cha)
  projectId String  @map("project_id")
  project Project @relation(fields: [projectId], references: [id])
  comments Comment[]

  @@map("tasks")
}


model Comment {
  id String @id @default(uuid())
  content String @map("content")
  userId String @map("user_id")
  taskId String @map("task_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt  @map("updated_at")

  // Relations 
  user User @relation(fields: [userId], references: [id])
  task Task @relation(fields: [taskId], references: [id])

  @@map("comments")
}

